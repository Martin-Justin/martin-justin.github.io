    title: "Coherence as a Constraint on Scientific Inquiry",
    coauthors: "with Borut Trpin",
    venue: "Synthese (2025)",
    links: [
      { text: "[Synthese]", url: "https://link.springer.com/article/10.1007/s11229-025-05281-3" }
    ],
    abstract: "The paper uses an agent-based model to investigates the epistemic role of coherence in scientific reasoning, focusing on its use as a heuristic for filtering evidence."
  },
  {
    num: "[02]",
    title: "The Mix Matters: Exploring the Interplay Between Epistemic and Zetetic Norms in Scientific Disagreement",
    coauthors: "with Dunja Šešelja, Christian Straßer, and Borut Trpin",
    venue: "The British Journal for the Philosophy of Science (2025)",
    links: [
      { text: "[The British Journal for the Philosophy of Science]", url: "https://www.journals.uchicago.edu/doi/10.1086/737742" }
    ],
    abstract: " Although conciliatory approach to disagreement is widely regarded as a norm of individual rationality, its value in the context of collective scientific inquiry is less clear. We should that this worry is misplaced."
  },
  {
    num: "[03]",
    title: "More Hope for Conciliationism",
