<Layout title="Research | Martin Justin">
  <h1 class="page-title">Publications & Talks</h1>
  
  <section>
    <h2 class="section-title"><span class="section-number">I.</span>Selected Publications</h2>
    <div class="publications-list">
      {publications.map((pub, idx) => {
        const pubNum = `[${String(publications.length - idx).padStart(2, '0')}]`;
        return (
          <article class="publication-item" id={pubNum.slice(1, -1)}>
            <div class="pub-number">{pubNum}</div>
            <div class="pub-content">
              <h3 class="pub-title">{pub.title}</h3>
              <p class="pub-meta">{pub.coauthors && <span>{pub.coauthors} • </span>}<em>{pub.venue}</em></p>
              <div class="pub-abstract">
                {pub.abstract}
              </div>
              <div class="pub-links">
                {pub.links.map((link) => (
                  <a href={link.url} target="_blank" rel="noopener noreferrer" class="pub-link">{link.text}</a>
                ))}
              </div>
            </div>
          </article>
        );
      })}
    </div>
  </section>

  <section>
    <h2 class="section-title"><span class="section-number">II.</span>Work in Progress</h2>
    {wip.length === 0 ? (
      <p class="work-in-progress-empty"><em>Working papers and drafts will be listed here.</em></p>
    ) : (
      <div class="publications-list">
        {wip.map((item, idx) => {
          const wipNum = `[${String(wip.length - idx).padStart(2, '0')}]`;
          return (
            <article class="publication-item" id={`wip-${wipNum.slice(1, -1)}`}>
              <div class="pub-number">{wipNum}</div>
              <div class="pub-content">
                <h3 class="pub-title">{item.title}</h3>
                <p class="pub-meta">{item.coauthors && <span>{item.coauthors} • </span>}<em>{item.status}</em></p>
                <div class="pub-abstract">
                  {item.abstract}
                </div>
                {item.links && item.links.length > 0 && (
                  <div class="pub-links">
                    {item.links.map((link) => (
                      <a href={link.url} target="_blank" rel="noopener noreferrer" class="pub-link">{link.text}</a>
                    ))}
                  </div>
                )}
              </div>
            </article>
          );
        })}
      </div>
    )}
  </section>

  <section>
    <h2 class="section-title"><span class="section-number">III.</span>Academic Talks</h2>
    <div class="talks-list">
      {talks.map((talk, idx) => {
        const talkNum = `[${String(talks.length - idx).padStart(2, '0')}]`;
        return (
          <div class="talk-item">
            <div class="talk-num">{talkNum}</div>
            <div class="talk-details">
              <h3 class="talk-title">{talk.title}</h3>
              <p class="talk-meta">{talk.venue} • <span class="talk-date">{talk.date}</span></p>
            </div>
          </div>
        );
      })}
    </div>
  </section>
</Layout>

<style>
  .page-title {
    font-size: 1.4rem;
    margin-bottom: 2rem;
    letter-spacing: 0.15em;
  }

  .publications-list {
    margin-top: 1rem;
  }

  .publication-item {
    display: flex;
    gap: 1rem;
    margin-bottom: 2.2rem;
  }

  .pub-number, .talk-num {
    font-size: 0.8rem;
    color: var(--text-muted);
    font-weight: 700;
    min-width: 1.8rem;
    padding-top: 0.15rem;
    flex-shrink: 0;
  }

  .pub-title {
    font-size: 1.05rem;
    margin: 0 0 0.15rem 0;
    letter-spacing: 0.02em;
  }

  .pub-meta {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin: 0 0 0.5rem 0;
  }

  .pub-abstract {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-bottom: 0.6rem;
    text-align: left;
    line-height: 1.5;
  }

  .pub-links {
    display: flex;
    gap: 1rem;
    margin-top: 0.5rem;
  }

  .pub-link {
    font-size: 0.8rem;
    font-weight: 700;
    text-decoration: none;
    letter-spacing: 0.05em;
  }

  .pub-link:hover {
    text-decoration: underline;
  }

  /* Talks List */
  .talks-list {
    margin-top: 1rem;
  }

  .talk-item {
    display: flex;
    gap: 1rem;
    margin-bottom: 1rem;
  }

  .talk-title {
    font-size: 1rem;
    margin: 0 0 0.15rem 0;
  }

  .talk-meta {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin: 0;
  }

  .talk-date {
    font-weight: 700;
  }

  .work-in-progress-empty {
    font-size: 0.95rem;
    color: var(--text-muted);
    font-style: italic;
    margin-top: 0.5rem;
    text-indent: 0 !important;
  }
</style>
