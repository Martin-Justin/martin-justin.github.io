<script>
  const setupCVToggle = () => {
    const btnSummary = document.getElementById('mode-summary');
    const btnFull = document.getElementById('mode-full');
    const cvRoot = document.getElementById('cv-root');
    if (!btnSummary || !btnFull || !cvRoot) return;

    const showSummary = () => {
      btnSummary.classList.add('active');
      btnSummary.setAttribute('aria-pressed', 'true');
      btnFull.classList.remove('active');
      btnFull.setAttribute('aria-pressed', 'false');
      cvRoot.classList.remove('show-full-cv');
    };

    const showFull = () => {
      btnFull.classList.add('active');
      btnFull.setAttribute('aria-pressed', 'true');
      btnSummary.classList.remove('active');
      btnSummary.setAttribute('aria-pressed', 'false');
      cvRoot.classList.add('show-full-cv');
    };

    btnSummary.addEventListener('click', showSummary);
    btnFull.addEventListener('click', showFull);
  };

  setupCVToggle();
  document.addEventListener('astro:after-swap', setupCVToggle);
</script>

<style>
  .cv-header-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .page-title {
    font-family: 'Inter', -apple-system, sans-serif !important;
    font-size: 1.15rem;
    margin: 0;
    letter-spacing: 0.12em;
    text-transform: none;
  }

  .cv-controls {
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  /* Typewriter Mode Selector */
  .mode-selector {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-family: 'Inter', -apple-system, sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.08em;
  }

  .mode-btn {
    background: none;
    border: none;
    font-family: inherit;
    font-size: inherit;
    color: var(--text-muted);
    cursor: pointer;
    padding: 0;
    transition: color 0.1s ease;
  }

  .mode-btn.active {
    color: var(--text-primary);
    font-weight: 700;
    text-decoration: underline;
  }

  .mode-btn:hover {
    color: var(--text-primary);
  }

  .mode-separator {
    color: var(--text-muted);
  }

  /* PDF Print Link */
  .pdf-btn {
    background: none;
    border: none;
    font-family: 'Inter', -apple-system, sans-serif;
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    color: var(--text-primary);
    cursor: pointer;
    padding: 0;
  }

  .pdf-btn:hover {
    text-decoration: underline;
  }

  /* Standard Professional CV Typography Override */
  .cv-paper {
    font-family: Georgia, Garamond, "Times New Roman", serif;
    font-size: 0.9rem;
    line-height: 1.45;
    padding: 0.5rem 0;
  }

  .cv-paper p {
    text-align: left;
    text-indent: 0 !important; /* No paragraph indents for standard CVs */
    margin: 0 0 0.4rem 0;
  }

  .cv-meta-info {
    margin-bottom: 2rem;
    font-size: 0.85rem;
    color: var(--text-muted);
    font-family: inherit;
  }

  .cv-meta-info p {
    margin: 0 0 0.15rem 0;
  }

  /* CV Sections */
  .cv-section {
    margin-bottom: 2rem;
  }

  .cv-section-title {
    font-family: Georgia, Garamond, serif !important;
    font-size: 1.05rem;
    font-weight: bold;
    text-transform: none !important;
    letter-spacing: 0 !important;
    margin-top: 0;
    margin-bottom: 1rem;
    border-bottom: 1px solid var(--border-color); /* Faint rule under headers */
    padding-bottom: 0.25rem;
  }

  .cv-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media (min-width: 640px) {
    .cv-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  .cv-subheading {
    font-family: Georgia, Garamond, serif !important;
    font-size: 0.95rem;
    margin-top: 0;
    margin-bottom: 0.35rem;
    font-weight: bold;
    text-transform: none !important;
    letter-spacing: 0 !important;
  }

  .cv-text {
    font-size: 0.9rem;
    margin: 0;
    color: var(--text-muted);
  }

  @media (max-width: 639px) {
    .cv-margin-top-mobile {
      margin-top: 0.8rem;
    }
  }

  /* CV Timeline */
  .cv-timeline {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .cv-entry {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  @media (min-width: 640px) {
    .cv-entry {
      flex-direction: row;
      gap: 1.5rem;
    }
  }

  .cv-entry-date {
    font-size: 0.9rem;
    font-weight: bold;
    color: var(--text-primary);
    min-width: 6.5rem;
  }

  .cv-entry-title {
    font-family: Georgia, Garamond, serif !important;
    font-size: 0.95rem;
    margin: 0;
    font-weight: bold;
    text-transform: none !important;
    letter-spacing: 0 !important;
  }

  .cv-entry-location {
    font-size: 0.85rem;
    color: var(--text-muted);
    font-style: italic;
    margin: 0;
  }

  .cv-entry-details {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin: 0.15rem 0 0 0;
  }

  /* CV Listings */
  .cv-listings {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .cv-list-item {
    display: flex;
    gap: 1rem;
    font-size: 0.9rem;
    align-items: flex-start;
  }

  .cv-list-marker {
    color: var(--text-muted);
    font-weight: bold;
    min-width: 6.5rem;
    flex-shrink: 0;
  }

  /* Toggle CV Visibility */
  .cv-detail-only {
    display: none;
  }

  :global(.show-full-cv) .cv-detail-only {
    display: block !important;
  }
  
  :global(.show-full-cv) div.cv-detail-only.cv-list-item {
    display: flex !important;
  }

  .print-only {
    display: none;
  }

